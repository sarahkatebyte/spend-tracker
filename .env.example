# Elasticsearch connection
# Get ES_HOST from cloud.elastic.co → your deployment → Copy endpoint
# Format: https://<deployment-id>.<region>.gcp.cloud.es.io:443
ES_HOST=https://your-deployment-id.us-central1.gcp.cloud.es.io:443
ES_API_KEY=your-api-key-here

# Optional: Hugging Face token for higher rate limits on model downloads
# HF_TOKEN=your-hf-token-here
